# clangd 配置 — NandinaUI (C++26 + C++20 Modules)
#
# 编译数据库指向 CMake linux-clang-debug 预设的输出目录。
# 使用其他预设时请相应修改 CompilationDatabase 路径。
#
# ⚠ clangd 对 C++20 Modules 的支持需要：
#   1. CMake 4.x 已配置并生成 compile_commands.json
#   2. 项目至少构建过一次（生成 @*.modmap 响应文件与 .pcm 模块文件）
#   3. 当模块依赖关系变化时需重新构建以更新 .pcm 文件
#
# 首次使用：
#   cmake --preset linux-clang-debug
#   cmake --build --preset linux-clang-debug -j$(nproc)

# ⚠ clangd 对 C++20 Modules 的支持依赖 compile_commands.json 中已有的
# -fmodule-file= 标志。CMake 生成的编译数据库已包含全部模块依赖映射，
# clangd 直接透传这些标志给 clang 解析器即可正常工作。
# 不要启用 --experimental-modules-support：clangd 22 该标志有 SIGSEGV 崩溃 bug，
# 且本项目无需 clangd 自行管理模块依赖（.pcm 由 CMake 构建生成）。

CompileFlags:
    # 注意：如果在 CLion 中使用其他构建配置，请相应修改此路径
    # CLion 默认使用 linux-clang-release，若切换到 debug 请改为 build/linux-clang-debug
    CompilationDatabase: build/linux-clang-release

    # CMake 使用响应文件 (@*.modmap) 传递模块标志，compile_commands.json 中
    # 直接引用 @path/to/file.modmap。clangd 透传此命令给 clang 驱动，驱动会
    # 自动展开 @file 并解析其中的 -x c++-module、-fmodule-file=、-fmodule-output= 等标志。
    # 因此无需在此添加任何模块相关标志。
    #
    # 不添加 -fmodules：该标志启用的是 Clang Modules（基于 modulemap 的旧模块系统），
    # 与 C++20 Modules 无关。开启它会导致系统头文件尝试使用模块映射，引发
    # _Builtin_inttypes 等内置模块查找错误。
    #
    # CMake 在 linux-gcc-* 预设下会向 compile_commands.json 写入 GCC 专有
    # 模块扫描参数（-fmodules-ts, -fmodule-mapper=* 等），clangd 使用 Clang
    # 驱动无法识别这些参数，在此提前移除。
    Remove:
        - -fmodules-ts
        - -fmodule-mapper=*
        - -fdeps-format=*
        - -fdeps-file=*
        - -fmodules
    Add:
        - -std=c++26
        - -Wall
        - -Wextra
        - -Wpedantic

Diagnostics:
    ClangTidy:
        Add:
            - bugprone-*
            - modernize-*
            - performance-*
            - readability-*
        Remove:
            - modernize-use-trailing-return-type
    UnusedIncludes: Strict

Index:
    Background: Build

InlayHints:
    Enabled: Yes
    ParameterNames: Yes
    DeducedTypes: Yes
    BlockEnd: No
