{
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 0,
    "patch": 0
  },
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-clang-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "windows-msvc-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Windows Clang Debug",
      "description": "Windows x64 Clang Debug",
      "inherits": "windows-clang-base",
      "binaryDir": "${sourceDir}/build/windows-clang-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANDINA_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-clang-release",
      "displayName": "Windows Clang Release",
      "description": "Windows x64 Clang Release",
      "inherits": "windows-clang-base",
      "binaryDir": "${sourceDir}/build/windows-clang-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NANDINA_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "description": "Windows x64 MSVC Debug",
      "inherits": "windows-msvc-base",
      "binaryDir": "${sourceDir}/build/windows-msvc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANDINA_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release",
      "description": "Windows x64 MSVC Release",
      "inherits": "windows-msvc-base",
      "binaryDir": "${sourceDir}/build/windows-msvc-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NANDINA_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "linux-clang-debug",
      "displayName": "Linux Clang Debug",
      "description": "Linux x64 Clang Debug",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/linux-clang-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANDINA_BUILD_TESTS": "ON",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-clang-release",
      "displayName": "Linux Clang Release",
      "description": "Linux x64 Clang Release",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/linux-clang-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NANDINA_BUILD_TESTS": "OFF",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "base",
      "hidden": true,
      "jobs": 0
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Windows Clang Debug",
      "configurePreset": "windows-clang-debug",
      "inherits": "base"
    },
    {
      "name": "windows-clang-release",
      "displayName": "Windows Clang Release",
      "configurePreset": "windows-clang-release",
      "inherits": "base"
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "configurePreset": "windows-msvc-debug",
      "inherits": "base"
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release",
      "configurePreset": "windows-msvc-release",
      "inherits": "base"
    },
    {
      "name": "linux-clang-debug",
      "displayName": "Linux Clang Debug",
      "configurePreset": "linux-clang-debug",
      "inherits": "base"
    },
    {
      "name": "linux-clang-release",
      "displayName": "Linux Clang Release",
      "configurePreset": "linux-clang-release",
      "inherits": "base"
    }
  ]
}
